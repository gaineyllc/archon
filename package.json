{
  "name": "onyx-agent",
  "version": "0.2.0",
  "description": "Local AI agents for NAS file cataloguing, dedup/organisation (SMB/NFS), and torrent hunting via IPTorrents + Synology Download Station. Runs fully local on GPU via Ollama.",
  "keywords": [
    "mcp",
    "ai-agent",
    "nas",
    "ollama",
    "langgraph",
    "smb",
    "nfs",
    "synology",
    "torrent",
    "file-organizer",
    "local-llm"
  ],
  "homepage": "https://github.com/gaineyinc/onyx-agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/gaineyinc/onyx-agent.git"
  },
  "license": "MIT",
  "author": "Neil Gainey",
  "bin": {
    "onyx-agent": "./bin/onyx-agent.js"
  },
  "files": [
    "bin/",
    "src/",
    "pyproject.toml",
    "uv.lock",
    ".env.example",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/onyx-agent.js",
    "install-python": "uv sync"
  }
}
