# ── Graph Database ──────────────────────────────────────────────
GRAPH_BACKEND=neo4j             # neo4j (default) or kuzu (requires Python <=3.12)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=archon-local
# Neo4j browser UI: http://localhost:7474

# ── Ollama ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
AGENT_MODEL=llama3.2
NAS_AGENT_MODEL=llava          # multimodal — for image/video analysis

# ── API Server ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── NAS Cataloguer ──────────────────────────────────────────────
# Source URI — pick your protocol:
#   Local:  NAS_ROOT=C:\\Users\\...  or  /mnt/nas
#   SMB:    NAS_ROOT=smb://user:pass@192.168.1.x/share/media
#   NFS:    NAS_ROOT=nfs://192.168.1.x/volume1/media
NAS_ROOT=smb://user:pass@192.168.1.x/media
NAS_DRY_RUN=true               # set false to allow moves/deletes

# SMB credentials (used by smb_from_env() helper)
SMB_HOST=192.168.1.x
SMB_SHARE=media
SMB_USER=your_user
SMB_PASS=your_password
SMB_DOMAIN=                    # leave blank for local accounts
SMB_ENCRYPT=false              # set true to require SMB3 encryption

# NFS settings (used by nfs_from_env() helper)
NFS_HOST=192.168.1.x
NFS_EXPORT=/volume1/media
NFS_VERSION=3                  # 3 or 4
NFS_READONLY=true              # set false to allow writes via NFS

# ── IPTorrents ──────────────────────────────────────────────────
IPTORRENTS_USER=your_username
IPTORRENTS_PASS=your_password
# IPTORRENTS_COOKIE=uid=xxx; pass=yyy   # alternative: paste cookie from browser

# ── Synology Download Station ───────────────────────────────────
SYNOLOGY_HOST=http://192.168.1.x:5000
SYNOLOGY_USER=your_dsm_user
SYNOLOGY_PASS=your_dsm_password
DS_DOWNLOAD_DIR_TV=/volume1/downloads/tv
DS_DOWNLOAD_DIR_MOVIES=/volume1/downloads/movies
