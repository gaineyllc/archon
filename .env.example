# ── Ollama ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
AGENT_MODEL=llama3.2
NAS_AGENT_MODEL=llava          # multimodal — for image/video analysis

# ── API Server ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── NAS Cataloguer ──────────────────────────────────────────────
NAS_ROOT=\\NAS\media            # UNC path or mount point
NAS_DRY_RUN=true               # set false to allow moves/deletes

# ── IPTorrents ──────────────────────────────────────────────────
IPTORRENTS_USER=your_username
IPTORRENTS_PASS=your_password
# IPTORRENTS_COOKIE=uid=xxx; pass=yyy   # alternative: paste cookie from browser

# ── Synology Download Station ───────────────────────────────────
SYNOLOGY_HOST=http://192.168.1.x:5000
SYNOLOGY_USER=your_dsm_user
SYNOLOGY_PASS=your_dsm_password
DS_DOWNLOAD_DIR_TV=/volume1/downloads/tv
DS_DOWNLOAD_DIR_MOVIES=/volume1/downloads/movies
